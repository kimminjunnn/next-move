# Copy this file to .env on the Lightsail server before running docker compose.
# Keep .env out of git.

# Directory on the server that contains best.pt.
RUPA_MODEL_DIR=/opt/rupa/models

# Public host port for the Nest API.
NEST_API_PORT=3000

# How long Nest waits for YOLO wall analysis before returning 504.
VISION_SERVICE_TIMEOUT_MS=60000
